# Copia este archivo a .env y rellena los valores. No subas .env al repositorio.

# CoinEx API (desde https://www.coinex.com/account/apis)
COINEX_API_KEY=tu_coinex_api_key_aqui
COINEX_SECRET=tu_coinex_secret_aqui

# Telegram: crea un bot con @BotFather y obtén el token; chat_id con @userinfobot
TELEGRAM_BOT_TOKEN=tu_telegram_bot_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# --- IA: elige un proveedor (no hace falta OpenAI si usas Groq, Gemini u Ollama) ---
# AI_PROVIDER: openai | groq | gemini | ollama
# groq = gratis en https://console.groq.com | gemini = gratis en https://aistudio.google.com/apikey | ollama = local, sin clave
AI_PROVIDER=groq
OPENAI_API_KEY=tu_openai_api_key_aqui
GROQ_API_KEY=tu_groq_api_key_aqui
GOOGLE_API_KEY=tu_google_api_key_aqui
OLLAMA_HOST=http://localhost:11434
# Modelos por proveedor (opcionales; hay valores por defecto)
OPENAI_MODEL=gpt-4o-mini
GROQ_MODEL=llama-3.1-8b-instant
GEMINI_MODEL=gemini-2.0-flash
OLLAMA_MODEL=llama2

# JWT Secret (genera uno con: openssl rand -hex 32)
SECRET_KEY=tu_jwt_secret_aqui

# Modo test: true = no envía órdenes reales a CoinEx
TEST_MODE=false

# Pares a operar (separados por coma)
PAIRS=BTC/USDT,ETH/USDT,SOL/USDT

# Timeframe de velas: 1m, 5m, 15m, 1h, 4h, 1d
TIMEFRAME=15m

# Velas a obtener (50+ mejora MACD/SMA200; más = mejor contexto)
CANDLE_COUNT=50

# Velas recientes en el prompt a la IA (más = mejor decisión, más tokens)
PROMPT_CANDLES=10

# Umbral de confianza (0-1) para ejecutar orden
CONFIDENCE_THRESHOLD=0.7

# Monto por orden por par (base): PAR:CANTIDAD separados por coma
ORDER_AMOUNT_PER_PAIR=BTC/USDT:0.001,ETH/USDT:0.01,SOL/USDT:1

# Intervalo entre ciclos completos (segundos), ej. 300 = 5 min
INTERVAL=300

# Pausa entre cada par en un ciclo (segundos)
PAIR_DELAY=2

# Límite de trades por día por par (seguridad)
MAX_TRADES_PER_DAY_PER_PAIR=5

# Stop-loss porcentaje (opcional, para lógica futura)
STOP_LOSS_PERCENT=2.0

# Log (logs diarios por defecto: un archivo por día en la carpeta logs/)
LOG_DIR=logs
LOG_FILE=trading_bot.log
LOG_DAILY=true
LOG_BACKUP_DAYS=30
LOG_LEVEL=INFO

# Email (notificación de trades ejecutados)
# Usa Gmail con App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASSWORD=tu_app_password_aqui
EMAIL_FROM=tu_correo@gmail.com
